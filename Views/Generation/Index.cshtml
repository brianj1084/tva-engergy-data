@model TvaGenerationViewModel
@{
    ViewData["Title"] = "TVA Generation Dashboard";
}

@functions {
    string FuelBadgeClass(string fuelType) => fuelType switch
    {
        "COL" => "bg-secondary",
        "NG"  => "bg-primary",
        "NUC" => "bg-warning text-dark",
        "WAT" => "bg-info text-dark",
        "SUN" => "bg-orange text-dark",
        "WND" => "bg-success",
        "PS"  => "bg-dark",
        "BAT" => "bg-info",
        "OIL" => "bg-danger",
        _     => "bg-secondary"
    };

    string StatusBadgeClass(string status) => status switch
    {
        "OP" => "bg-success",
        "SB" => "bg-warning text-dark",
        "OA" => "bg-info text-dark",
        _    => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">TVA Generation Dashboard</h1>
    @if (Model.HourlyDataPeriod != null)
    {
        <span class="text-muted small">Last updated: <strong>@Model.HourlyDataPeriod UTC</strong></span>
    }
</div>

@if (Model.ErrorMessage != null)
{
    <div class="alert alert-warning">@Model.ErrorMessage</div>
}

<!-- Summary Stats -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 bg-light">
            <div class="card-body text-center py-3">
                <div class="h4 fw-bold mb-0">
                    @Model.TotalGenerationMw.ToString("N0")
                    <small class="fs-6 fw-normal text-muted">MW</small>
                </div>
                <div class="text-muted small">Current Net Generation</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-light">
            <div class="card-body text-center py-3">
                <div class="h4 fw-bold mb-0">
                    @Model.TotalCapacityMw.ToString("N0")
                    <small class="fs-6 fw-normal text-muted">MW</small>
                </div>
                <div class="text-muted small">Total Nameplate Capacity</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-light">
            <div class="card-body text-center py-3">
                <div class="h4 fw-bold mb-0">
                    @Model.PlantGroups.Count
                    <small class="fs-6 fw-normal text-muted">plants /</small>
                    @Model.TotalUnitCount
                    <small class="fs-6 fw-normal text-muted">units</small>
                </div>
                <div class="text-muted small">Generating Facilities</div>
            </div>
        </div>
    </div>
</div>

<!-- Hourly Generation by Fuel Type -->
<h2 class="h5 mb-3">
    Current Generation by Fuel Type
    <small class="text-muted fw-normal fs-6">— hourly average MW (EIA-930)</small>
</h2>
<div class="row g-3 mb-5">
    @foreach (var entry in Model.HourlyGeneration)
    {
        var isNegative = entry.ValueMw < 0;
        var pct = Model.TotalGenerationMw > 0 ? Math.Max(0, entry.ValueMw / Model.TotalGenerationMw * 100) : 0;
        <div class="col-6 col-md-4 col-lg-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body p-3">
                    <span class="badge @FuelBadgeClass(entry.FuelType) mb-2">@entry.TypeName</span>
                    <div class="fs-5 fw-bold @(isNegative ? "text-danger" : "")">
                        @entry.ValueMw.ToString("N0")
                        <small class="fs-6 fw-normal text-muted">MW</small>
                    </div>
                    <div class="progress mt-2" style="height: 4px;" title="@pct.ToString("F1")% of total">
                        <div class="progress-bar @FuelBadgeClass(entry.FuelType).Split(' ')[0]"
                             style="width: @pct.ToString("F1")%"></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Generating Units by Plant -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="h5 mb-0">Generating Units by Plant</h2>
    @if (Model.UnitsDataPeriod != null)
    {
        <small class="text-muted">EIA-860M inventory as of @Model.UnitsDataPeriod</small>
    }
</div>

@foreach (var plant in Model.PlantGroups)
{
    <div class="card mb-3 shadow-sm">
        <div class="card-header py-2 d-flex justify-content-between align-items-center">
            <strong>@plant.PlantName</strong>
            <span class="text-muted small">
                @plant.StateName &nbsp;&bull;&nbsp;
                @plant.Generators.Count unit@(plant.Generators.Count != 1 ? "s" : "") &nbsp;&bull;&nbsp;
                @plant.TotalCapacityMw.ToString("N0") MW nameplate
            </span>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-striped table-hover mb-0">
                <thead class="table-light small">
                    <tr>
                        <th>Unit ID</th>
                        <th>Technology</th>
                        <th>Fuel</th>
                        <th class="text-end">Nameplate (MW)</th>
                        <th class="text-end">Net Summer (MW)</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody class="small">
                    @foreach (var unit in plant.Generators)
                    {
                        <tr>
                            <td class="fw-semibold">@unit.GeneratorId</td>
                            <td>@unit.Technology</td>
                            <td>@unit.EnergySourceDesc</td>
                            <td class="text-end">@unit.NameplateMw.ToString("N1")</td>
                            <td class="text-end">@unit.NetSummerMw.ToString("N1")</td>
                            <td>
                                <span class="badge @StatusBadgeClass(unit.Status)">@unit.StatusDescription</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
